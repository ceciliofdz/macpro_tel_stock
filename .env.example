# Variables de entorno para MACD PRO Telegram Bot
# Copia este archivo a .env y completa los valores.

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
FAST_LEN=12
SLOW_LEN=26
SIGNAL_LEN=9
SOURCE_TYPE=close
OSC_MA_TYPE=EMA
SIGNAL_MA_TYPE=EMA
USE_TREND_FILTER=true
TREND_FILTER_MODE=Ambas
TREND_EMA_LEN=200
TIMEFRAME=1h
CHECK_INTERVAL_MINUTES=5
